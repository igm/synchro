#!/bin/bash

# Synchro - File Synchronization CLI Tool
# Syncs two directories with bidirectional (default) or mirror mode

set -euo pipefail

# Colors for output (defined before trap)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default options
MIRROR=false
DRY_RUN=false
QUIET=false
USE_CHECKSUM=false

# Check for rsync availability
command -v rsync &>/dev/null || {
    echo -e "${RED}Error: rsync is required but not installed.${NC}" >&2
    exit 1
}

# Trap errors for better messaging (respects QUIET)
trap 'if [[ "$QUIET" != "true" ]]; then echo -e "${RED}Error: Command failed at line $LINENO${NC}" >&2; fi' ERR

# Help text
show_help() {
    cat << EOF
Synchro - File Synchronization Tool

USAGE:
    synchro [OPTIONS] <SOURCE> <TARGET>

OPTIONS:
    -m, --mirror    Mirror mode: source → target (deletes files in target not in source)
    -d, --dry-run   Preview changes without making them
    -c, --checksum  Use checksums for file comparison (slower but more reliable)
    -q, --quiet     Suppress output
    -h, --help      Show this help message

MODES:
    Bidirectional (default):
        - Copies missing/newer files in both directions
        - Both locations end up with the union of all files
        - Never deletes files (additive only)
        - Newer files win on conflicts (based on modification time)

    Mirror (--mirror):
        - Copies all files from source to target
        - Deletes files in target that don't exist in source
        - Target becomes an exact copy of source
        - Destructive operation

NOTE:
    By default, rsync uses file size and modification time to decide which files
    to transfer. Use --checksum for more accurate comparison (useful for network
    drives or when mtime is unreliable), at the cost of slower performance.

EXAMPLES:
    synchro ~/Projects /Volumes/Backup/Projects
    synchro --mirror ~/Source ~/Target
    synchro --dry-run ~/Projects /Volumes/Backup/Projects
    synchro -c --mirror ~/Source /mnt/backup
EOF
}

# Log function (guards on QUIET)
log() {
    if [[ "$QUIET" != "true" ]]; then
        echo -e "$1"
    fi
}

# Parse arguments
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -m|--mirror)
            MIRROR=true
            shift
            ;;
        -d|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -c|--checksum)
            USE_CHECKSUM=true
            shift
            ;;
        -q|--quiet)
            QUIET=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo -e "${RED}Error: Unknown option $1${NC}" >&2
            show_help
            exit 1
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

# Handle case where no positional args provided
if [[ ${#POSITIONAL_ARGS[@]} -eq 0 ]]; then
    echo -e "${RED}Error: Missing required arguments${NC}" >&2
    show_help
    exit 1
fi

set -- "${POSITIONAL_ARGS[@]}"

# Validate arguments
if [[ $# -lt 2 ]]; then
    echo -e "${RED}Error: Missing required arguments${NC}" >&2
    show_help
    exit 1
fi

if [[ $# -gt 2 ]]; then
    echo -e "${RED}Error: Too many arguments${NC}" >&2
    show_help
    exit 1
fi

SOURCE="${1%/}"
TARGET="${2%/}"

# Validate paths exist
if [[ ! -d "$SOURCE" ]]; then
    echo -e "${RED}Error: Source directory does not exist: $SOURCE${NC}" >&2
    exit 1
fi

if [[ ! -d "$TARGET" ]]; then
    echo -e "${RED}Error: Target directory does not exist: $TARGET${NC}" >&2
    exit 1
fi

# Resolve to absolute physical paths (resolve symlinks)
SOURCE="$(cd -P "$SOURCE" && pwd)"
TARGET="$(cd -P "$TARGET" && pwd)"

# Prevent syncing a directory to itself
if [[ "$SOURCE" == "$TARGET" ]]; then
    echo -e "${RED}Error: Source and target are the same directory${NC}" >&2
    exit 1
fi

# Prevent parent/child directory sync (causes infinite recursion)
# Use trailing slash to avoid false positives on sibling dirs (e.g., /foo vs /foobar)
if [[ "$SOURCE" == "$TARGET/"* ]]; then
    echo -e "${RED}Error: Target is a subdirectory of source${NC}" >&2
    echo -e "${RED}This would cause infinite recursion.${NC}" >&2
    exit 1
fi
if [[ "$TARGET" == "$SOURCE/"* ]]; then
    echo -e "${RED}Error: Source is a subdirectory of target${NC}" >&2
    echo -e "${RED}This would cause infinite recursion.${NC}" >&2
    exit 1
fi

# Build rsync options
RSYNC_OPTS=(-a --human-readable)

if $DRY_RUN; then
    RSYNC_OPTS+=(--dry-run)
fi

if [[ "$QUIET" == "true" ]]; then
    RSYNC_OPTS+=(--quiet)
fi

if $USE_CHECKSUM; then
    RSYNC_OPTS+=(--checksum)
fi

# Perform sync
if $MIRROR; then
    # Mirror mode: source → target with delete
    log "${BLUE}Mirror mode: $SOURCE → $TARGET${NC}"
    # Always warn about destructive operation, regardless of QUIET
    echo -e "${YELLOW}Warning: Files in target not in source will be deleted${NC}" >&2

    if ! rsync "${RSYNC_OPTS[@]}" --delete "$SOURCE/" "$TARGET/"; then
        log "${RED}Warning: rsync completed with some errors${NC}"
    fi

    if $DRY_RUN; then
        log "${GREEN}Dry run complete. No changes made.${NC}"
    else
        log "${GREEN}Mirror sync complete.${NC}"
    fi
else
    # Bidirectional mode: sync both ways
    log "${BLUE}Bidirectional mode: $SOURCE ↔ $TARGET${NC}"

    if $USE_CHECKSUM; then
        log "${BLUE}Using checksum mode for file comparison${NC}"
    fi

    # Sync source → target
    log "${BLUE}Pass 1: $SOURCE → $TARGET${NC}"
    if ! rsync "${RSYNC_OPTS[@]}" --update "$SOURCE/" "$TARGET/"; then
        log "${RED}Warning: Pass 1 completed with some errors${NC}"
    fi

    # Sync target → source
    log "${BLUE}Pass 2: $TARGET → $SOURCE${NC}"
    if ! rsync "${RSYNC_OPTS[@]}" --update "$TARGET/" "$SOURCE/"; then
        log "${RED}Warning: Pass 2 completed with some errors${NC}"
    fi

    if $DRY_RUN; then
        log "${GREEN}Dry run complete. No changes made.${NC}"
    else
        log "${GREEN}Bidirectional sync complete.${NC}"
    fi
fi
